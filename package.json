{
	"name": "@magicappdev/mobile",
	"version": "0.0.10",
	"private": true,
	"description": "An mobile app built with Ionic to build apps with MagicAppDev",
	"type": "module",
	"scripts": {
		"android": "ionic capacitor run android -l --external",
		"prebuild": "bun run format && bun run lint:fix && bun run typecheck",
		"build": "tsc && vite build",
		"dev": "vite",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"ionic:build": "bun run build",
		"ionic:sync": "bunx cap sync",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"preview": "vite preview",
		"test.e2e": "cypress run",
		"test.unit": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@capacitor/android": "8.2.0",
		"@capacitor/app": "8.0.1",
		"@capacitor/browser": "^8.0.2",
		"@capacitor/core": "8.2.0",
		"@capacitor/haptics": "8.0.1",
		"@capacitor/keyboard": "8.0.1",
		"@capacitor/preferences": "^8.0.1",
		"@capacitor/status-bar": "8.0.1",
		"@eslint/js": "^9.39.2",
		"@ionic/react": "^8.8.1",
		"@ionic/react-router": "^8.8.1",
		"@marsidev/react-turnstile": "^1.4.2",
		"@types/bun": "^1.3.11",
		"@types/react-router": "^5.1.20",
		"@types/react-router-dom": "^5.3.3",
		"bun": "^1.3.11",
		"history": "^5.3.0",
		"ionicons": "^8.0.13",
		"jest": "^30.3.0",
		"prettier": "^3.8.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-router": "5.3.4",
		"react-router-dom": "5.3.4"
	},
	"devDependencies": {
		"@capacitor/cli": "8.2.0",
		"@involvex/prettier-config": "^0.0.4",
		"@testing-library/dom": ">=7.21.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.4.3",
		"@types/jest": "^30.0.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-legacy": "^8.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"cypress": "^13.5.0",
		"eslint": "^9.20.1",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"globals": "^15.15.0",
		"jsdom": "^22.1.0",
		"terser": "^5.4.0",
		"typescript": "~5.9.0",
		"typescript-eslint": "^8.24.0",
		"vite": "^8.0.1",
		"vitest": "^4.0.18"
	}
}
